# Required
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west1

# Vertex AI
VERTEX_MODEL=gemini-2.0-flash-001
VERTEX_MAX_OUTPUT_TOKENS=2048
VERTEX_TEMPERATURE=0.2
VERTEX_TOP_P=0.95

# Firestore
FIRESTORE_DB=(default)

# App
ENVIRONMENT=prod
FRONTEND_ORIGIN=https://your-frontend-cloud-run-url.run.app

# Admin API key — protects /api/v1/documents (ingest) endpoints.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=change-me-use-a-strong-random-string
